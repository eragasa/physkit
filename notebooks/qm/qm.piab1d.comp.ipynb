    "from physkit.qm.models.piab1d import ParticleInABox1D\n",
    "\n",
    "L = 1\n",
    "x_min = 0\n",
    "x_max = x_min + L\n",
    "model = ParticleInABox1D(\n",
    "    x_min=0.,\n",
    "    x_max=L,\n",
    "    Nx=50)\n",
    "model.solve()"
   ]
